# pyvid deployment config. Copy to `.env` and edit for your environment.
# IMPORTANT: the real `.env` file must never be committed to git.

# ----- Auth -----
# Comma-separated list of bearer tokens. Empty = auth disabled (dev only).
# Generate a strong one with:   openssl rand -hex 32
PYVID_API_TOKENS=change-me-generate-with-openssl-rand-hex-32

# ----- Networking (compose) -----
# Bind to loopback in production so only the reverse proxy can reach it.
# For local dev on your laptop, use 8000 (then http://127.0.0.1:8000).
PYVID_HOST_PORT=127.0.0.1:8000

# ----- Concurrency + rate limit -----
# Each worker launches a full Chromium (~500MB-1GB RAM). Raise carefully.
PYVID_CONCURRENCY=1

# Per-token sliding window (requests/minute). 0 = disabled.
PYVID_RATE_LIMIT=30
